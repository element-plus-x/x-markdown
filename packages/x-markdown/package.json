{
  "name": "@hejiayue/x-markdown-test",
  "version": "0.0.1-beta.137",
  "description": "A markdown component library for Vue",
  "type": "module",
  "main": "./dist/x-markdown.cjs.js",
  "module": "./dist/x-markdown.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/x-markdown.es.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/x-markdown.cjs.js"
      }
    },
    "./style": "./dist/style.css",
    "./vite-plugin": "./src/vite-plugin.js"
  },
  "files": [
    "dist",
    "src/vite-plugin.js"
  ],
  "sideEffects": [
    "*.css",
    "*.scss",
    "*.vue"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --project tsconfig.build.json",
    "lint": "eslint src --ext .ts,.tsx,.vue",
    "clean": "rm -rf dist node_modules"
  },
  "keywords": [
    "vue",
    "markdown",
    "component",
    "vue3"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "deepmerge": "^4.3.1",
    "dompurify": "^3.0.0",
    "element-plus": "^2.5.0",
    "hast": "^1.0.0",
    "lodash-es": "^4.17.21",
    "mdast": "^3.0.0",
    "mdast-util-to-hast": "^13.2.1",
    "property-information": "^7.1.0",
    "rehype": "^13.0.0",
    "rehype-katex": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "vue": "^3.3.0",
    "shiki": "^1.0.0 || ^3.0.0",
    "shiki-stream": "^0.1.4",
    "mermaid": "^10.0.0 || ^11.0.0"
  },
  "peerDependenciesMeta": {
    "shiki": {
      "optional": true
    },
    "shiki-stream": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.0",
    "@types/hast": "^3.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vueuse/core": "^14.1.0",
    "sass": "^1.70.0",
    "terser": "^5.44.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.3.0",
    "vue-tsc": "^2.0.0"
  }
}
